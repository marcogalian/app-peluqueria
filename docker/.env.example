# Plantilla para docker/.env
# Copiar a docker/.env y rellenar con valores reales (NO commitear .env).

# Postgres
DB_USER=
DB_PASSWORD=
DB_NAME=peluqueria_db

# Mailtrap (correos) — registrarse en mailtrap.io
MAILTRAP_USERNAME=
MAILTRAP_PASSWORD=
APP_ADMIN_EMAIL=admin@email.com

# URL base del frontend (para enlaces en emails de reset de contraseña)
FRONTEND_BASE_URL=http://localhost:3000

# IA del asistente
# Por defecto usa Gemini. Para probar OpenRouter:
# AI_PROVIDER=openrouter
AI_PROVIDER=gemini

# Gemini AI (chatbot) — crear key en aistudio.google.com/apikey
GEMINI_API_KEY=

# OpenRouter (opcional) — crear key en https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/free
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_APP_NAME=Peluqueria Isabella

# JWT (firma de tokens) — generar con: openssl rand -hex 32
JWT_SECRET_KEY=

# AES (chat interno cifrado) — generar con: openssl rand -hex 32
CHAT_AES_KEY=

# Password local para usuarios demo generados en el primer arranque
APP_DEMO_PASSWORD=
