# Plantilla para docker/.env
# Copiar a docker/.env y rellenar con valores reales (NO commitear .env).

# Postgres
DB_USER=
DB_PASSWORD=
DB_NAME=peluqueria_db

# Mailtrap (correos) - registrarse en mailtrap.io, copiar credenciales SMTP del inbox sandbox
MAILTRAP_USERNAME=
MAILTRAP_PASSWORD=

# Email del administrador y URL del frontend para enlaces de recuperacion
APP_ADMIN_EMAIL=admin@email.com
FRONTEND_BASE_URL=http://localhost:3000

# IA del asistente
# Por defecto el compose usa Spring AI. Para demo sin clave externa, dejar SPRING_AI_MODEL_CHAT=none.
AI_PROVIDER=spring-ai
SPRING_AI_MODEL_CHAT=none

# OpenAI con Spring AI (opcional)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-nano
OPENAI_MAX_TOKENS=200

# Compatibilidad opcional con proveedor antiguo. Normalmente se deja vacio.
GEMINI_API_KEY=

# Swagger UI (documentación de la API)
# true = visible en http://localhost:8080/swagger-ui.html (recomendado para demo/dev)
# false = desactivado en producción real
SWAGGER_ENABLED=false

# Anti-abuso: límites por IP y minuto para reducir scraping, fuerza bruta y coste de IA
ANTI_ABUSE_ENABLED=true
ANTI_ABUSE_GENERAL_PER_MINUTE=240
ANTI_ABUSE_AUTH_PER_MINUTE=20
ANTI_ABUSE_CHAT_PER_MINUTE=8

# JWT (firma de tokens) — generar con: openssl rand -hex 32
JWT_SECRET_KEY=

# AES (chat interno cifrado) — generar con: openssl rand -hex 32
CHAT_AES_KEY=

# Password local para usuarios demo generados en el primer arranque
APP_DEMO_PASSWORD=
